# Mosi Downloader Environment Configuration
# Copy this file to .env and customize values

# Maximum concurrent download jobs
MOSI_CONCURRENCY=3

# Public base URL for file downloads (used in Telegram notifications)
# Change this to your public-facing URL
MOSI_PUBLIC_BASE_URL=https://your-domain.com/viddown

# Telegram bot notifications (optional)
# Leave empty to disable Telegram notifications
MOSI_TELEGRAM_BOT_TOKEN=
MOSI_TELEGRAM_CHAT_ID=

# Job timeout in seconds (default: 30 minutes)
MOSI_JOB_TIMEOUT=1800
